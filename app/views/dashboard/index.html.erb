<script type="module">
import { gsap } from "gsap";

// GSAP Animations
document.addEventListener("DOMContentLoaded", () => {
  // Title animations
  gsap.to("#main-title", {
    opacity: 1,
    y: 0,
    duration: 1.2,
    ease: "power3.out"
  });
  
  gsap.to("#subtitle", {
    opacity: 1,
    y: 0,
    duration: 1,
    delay: 0.3,
    ease: "power3.out"
  });
  
  // Stat cards animation
  gsap.to(".stat-card", {
    scale: 1,
    opacity: 1,
    duration: 0.8,
    delay: 0.6,
    stagger: 0.1,
    ease: "back.out(1.7)"
  });
  
  // Action cards animation
  gsap.to(".action-card", {
    scale: 1,
    opacity: 1,
    duration: 0.8,
    delay: 1,
    stagger: 0.15,
    ease: "back.out(1.7)"
  });
  
  // Counter animations
  const animateCounter = (element, endValue) => {
    gsap.fromTo(element, 
      { innerText: 0 },
      { 
        innerText: endValue,
        duration: 2,
        delay: 1.2,
        snap: { innerText: 1 },
        ease: "power2.out"
      }
    );
  };
  
  // Simulate some data (replace with actual data from controller)
  animateCounter(document.getElementById("network-count"), 1247);
  animateCounter(document.getElementById("session-count"), 23);
  animateCounter(document.getElementById("open-count"), 89);
  
  // Coverage area animation
  gsap.fromTo("#coverage-area", 
    { innerText: "0 km²" },
    { 
      innerText: "45.7 km²",
      duration: 2,
      delay: 1.2,
      ease: "power2.out"
    }
  );
  
  // Button hover effects
  const buttons = document.querySelectorAll('[id$="-btn"]');
  buttons.forEach(button => {
    button.addEventListener('mouseenter', () => {
      gsap.to(button, {
        scale: 1.05,
        duration: 0.3,
        ease: "power2.out"
      });
    });
    
    button.addEventListener('mouseleave', () => {
      gsap.to(button, {
        scale: 1,
        duration: 0.3,
        ease: "power2.out"
      });
    });
  });
});
</script>
